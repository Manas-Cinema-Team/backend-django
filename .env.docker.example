# Django
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DJANGO_CORS_ALLOW_CREDENTIALS=True
DJANGO_TIME_ZONE=UTC
DJANGO_SECURE_SSL_REDIRECT=False

# Database
DB_ENGINE=django.db.backends.postgresql
DB_NAME=cinema_db
DB_USER=cinema_user
DB_PASSWORD=cinema_pass
DB_HOST=db
DB_PORT=5432
DB_CONN_MAX_AGE=60
DB_CONNECT_TIMEOUT=10
POSTGRES_DB=cinema_db
POSTGRES_USER=cinema_user
POSTGRES_PASSWORD=cinema_pass

# Auth
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# Booking
BOOKING_HOLD_MINUTES=10
SEAT_POLLING_INTERVAL_SECONDS=5

# Logging
DJANGO_LOG_LEVEL=INFO
DJANGO_FRAMEWORK_LOG_LEVEL=INFO
DJANGO_SERVER_LOG_LEVEL=INFO
DJANGO_PROJECT_LOG_LEVEL=INFO
DJANGO_BOOKINGS_LOG_LEVEL=INFO
